# Required: shared secret clients must send as X-API-Key header
API_KEY=change-me

# Optional
PORT=3000
DB_PATH=./data/orkut.db
DOCS_PUBLIC=true

# Optional: outbound proxy/proxies for upstream OrderKuota requests.
# One URL, or many comma-separated for round-robin rotation with passive
# health tracking (a failing proxy is skipped for 60s). Unset = direct.
# PROXY_URL=http://user:pass@proxy1:8080,http://user:pass@proxy2:8080
